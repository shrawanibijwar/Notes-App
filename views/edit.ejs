<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white p-10">

    <a href="/" class="text-blue-500">← Back</a>

    <h1 class="text-3xl mb-5">Edit File Name</h1>

    <form action="/edit" method="post">
        <input type="hidden" name="oldname" value="<%= filename %>">

        <input name="newname"
            class="bg-zinc-800 px-5 py-2 rounded-md outline-none w-1/3"
            type="text"
            placeholder="New Name">

        <input
            class="bg-yellow-600 px-5 py-2 rounded-md ml-2 cursor-pointer"
            type="submit"
            value="Update Title">
    </form>

</body>
</html>