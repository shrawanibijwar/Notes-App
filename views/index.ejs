<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
<link rel="icon" type="image/x-icon" href="favicon.ico?v=2">
      <title>Notes App</title>
     
</head>
<body>


   <div class="main w-full min-h-screen   bg-zinc-900"> 
   <div class="form pt-10  px-10  ">
    <form action="/create" method="post">
        <input  class="bg-zinc-800  text-white w-full rounded-md outline-none block  px-5 py-2 " type="text" placeholder="Title " name="title" >
      <textarea name="details" class="bg-zinc-800 w-full rounded-md text-white outline-none  mt-2 resize-none block px-5 py-2" placeholder="Write your task details"></textarea>
        <input   class=" bg-blue-600  px-5 py-2 rounded-md text-white mt-3 "type="Submit" value="Create Task">
    </form> </div>

<div class="task flex gap-3 flex-wrap  p-10"> 


<% if (files.length > 0) { %>

    <% files.forEach(function(val) { %>
         
        <div class="w-72 mt-5 px-3 py-4 rounded-md bg-zinc-800"> 
           <div class="flex justify-between items-center">
    <h1 class="text-white text-xl tracking-tighter break-all">
        <%= val %>
    </h1>

<a class="text-red-500 text-sm cursor-pointer"
   onclick="deleteFile('<%= val %>', this)">
   Delete
</a>
</div>
           
 <div class="flex mt-3 w-full justify-between">
                   <a class="text-blue-500 inline-block " href="/file/<%= val %>">Read more</a>
            <a class="text-zinc-600" href="/edit/<%= val %>"> Edit Name</a>
            </div>
        
        </div>

    <% }) %>

<% } else { %>

    <h3 class="text-zinc-600">No text yet</h3>

<% } %>

</div>

   </div>


   </div>  

<script>
function deleteFile(filename, element) {

    const confirmDelete = confirm("Are you sure you want to delete this file?");
    if (!confirmDelete) return;

    fetch(`/delete/${filename}`, {
        method: 'DELETE'
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            const card = element.closest('.w-72');
            card.remove();
        } else {
            alert("Delete failed");
        }
    })
    .catch(err => {
        console.error(err);
        alert("Error deleting file");
    });
}
</script>

</body>
</html>
   

</body>
</html>